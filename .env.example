# --- Database ---
# Supabase (managed): use the connection string from Project Settings → Database.
# Self-hosted: see docker-compose.yml in this directory.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/owner_builder

# Set to "pglite" to run against an embedded in-process Postgres (dev/demo only,
# data stored in .pglite/). Leave unset for a real Postgres.
DB_DRIVER=

# --- Supabase (auth + storage) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Dev-only escape hatch: when Supabase is not configured, set AUTH_MODE=dev to
# sign every request in as the seeded dev owner. NEVER set in production.
AUTH_MODE=

# --- AI (Phase 3 — gateway config only, no features yet) ---
# Server-side only. Never expose to the client bundle.
OPENROUTER_API_KEY=

# --- Webhooks ---
# Secret used to sign outbound webhook events (HMAC-SHA256).
WEBHOOK_SIGNING_SECRET=change-me

# --- App ---
NEXT_PUBLIC_APP_TZ=Australia/Melbourne
